<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back" />

        <TextView
            android:id="@+id/tvCameraName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivFullscreen"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_fullscreen" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/videoPreviewArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/black">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/camera_preview_placeholder"
            android:textColor="@color/text_hint"
            android:textSize="18sp" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/ptz_pad_bg">

        <TextView
            android:id="@+id/tvTabRealtime"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/camera_tab_realtime"
            android:textColor="@color/primary_blue"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTabRecording"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/camera_tab_recording"
            android:textColor="@color/text_hint"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTabMessage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/camera_tab_message"
            android:textColor="@color/text_hint"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTabScene"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/camera_tab_scene"
            android:textColor="@color/text_hint"
            android:textSize="14sp" />

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_dark">

        <ImageView
            android:id="@+id/ivVolume"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/bg_toolbar_item"
            android:padding="8dp"
            android:src="@drawable/ic_volume"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivFullscreenToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_toolbar_item"
            android:padding="8dp"
            android:src="@drawable/ic_fullscreen"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivVolume" />

        <LinearLayout
            android:id="@+id/ptzPad"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/bg_ptz_pad"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/zoomControls"
            app:layout_constraintStart_toEndOf="@id/ivVolume"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivPtzUp"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_ptz_up" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivPtzLeft"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_ptz_left" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/ivPtzRight"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_ptz_right" />

            </LinearLayout>

            <ImageView
                android:id="@+id/ivPtzDown"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_ptz_down" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/zoomControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivZoomIn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_toolbar_item"
                android:padding="8dp"
                android:src="@drawable/ic_zoom_in" />

            <TextView
                android:id="@+id/tvZoomLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:text="1x"
                android:textColor="@color/text_white"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/ivZoomOut"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_toolbar_item"
                android:padding="8dp"
                android:src="@drawable/ic_zoom_out" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FF2D3748" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBottomToolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/toolbar_bg"
        android:paddingVertical="4dp" />

</LinearLayout>
