<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:tint="@color/text_primary" />

        <TextView
            android:id="@+id/tvCameraName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivFullscreen"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_fullscreen"
            android:tint="@color/text_primary" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/videoPreviewArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/black">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/camera_preview_placeholder"
            android:textColor="@color/text_hint"
            android:textSize="18sp" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/white">

        <LinearLayout
            android:id="@+id/tvTabRealtime"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/camera_tab_realtime"
                android:textColor="@color/primary_blue"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:background="@color/primary_blue" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tvTabRecording"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/camera_tab_recording"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <View
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:background="@android:color/transparent" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tvTabMessage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/camera_tab_message"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <View
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:background="@android:color/transparent" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tvTabScene"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/camera_tab_scene"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <View
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:background="@android:color/transparent" />

        </LinearLayout>

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_light">

        <ImageView
            android:id="@+id/ivVolume"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/bg_toolbar_item_light"
            android:padding="8dp"
            android:src="@drawable/ic_volume"
            android:tint="@color/text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivFullscreenToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_toolbar_item_light"
            android:padding="8dp"
            android:src="@drawable/ic_fullscreen"
            android:tint="@color/text_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivVolume" />

        <LinearLayout
            android:id="@+id/ptzPad"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/bg_ptz_pad_light"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/zoomControls"
            app:layout_constraintStart_toEndOf="@id/ivVolume"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivPtzUp"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_ptz_up"
                android:tint="@color/text_secondary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivPtzLeft"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_ptz_left"
                    android:tint="@color/text_secondary" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/ivPtzRight"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_ptz_right"
                    android:tint="@color/text_secondary" />

            </LinearLayout>

            <ImageView
                android:id="@+id/ivPtzDown"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_ptz_down"
                android:tint="@color/text_secondary" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/zoomControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivZoomIn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_toolbar_item_light"
                android:padding="8dp"
                android:src="@drawable/ic_zoom_in"
                android:tint="@color/text_primary" />

            <TextView
                android:id="@+id/tvZoomLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:text="1x"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/ivZoomOut"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_toolbar_item_light"
                android:padding="8dp"
                android:src="@drawable/ic_zoom_out"
                android:tint="@color/text_primary" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <include
        android:id="@+id/bottomToolbar"
        layout="@layout/layout_bottom_toolbar" />

</LinearLayout>
